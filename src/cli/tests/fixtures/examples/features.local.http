# Curated local mirror covering chaining, arrays, conditionals, stateful endpoints, and delays.

@expected_user_name=testuser123

###

# @name authenticate
POST __BASE_URL__/post
Content-Type: application/json
Authorization: Bearer secret-token

{
  "username": "admin@example.com",
  "access_token": "token-123",
  "user_id": "admin_001",
  "role": "administrator"
}

EXPECTED_RESPONSE_STATUS 200

###

# @name get_admin_data
GET __BASE_URL__/get?user={{authenticate.response.body.$.json.user_id}}
Authorization: Bearer {{authenticate.response.body.$.json.access_token}}
X-User-Role: {{authenticate.response.body.$.json.role}}
X-User-ID: {{authenticate.response.body.$.json.user_id}}

> EXPECTED_RESPONSE_STATUS 200
EXPECTED_RESPONSE_BODY "admin_001"

###

# @name array_source
POST __BASE_URL__/post
Content-Type: application/json

{
  "items": [
    {"id": 1, "name": "first"},
    {"id": 2, "name": "second"}
  ],
  "data": {
    "versions": [
      {"version": "3.0.0", "status": "stable"}
    ]
  }
}

EXPECTED_RESPONSE_STATUS 200

###

GET __BASE_URL__/get?first={{array_source.response.body.$.json.items[0].name}}&version={{array_source.response.body.$.json.data.versions[0].version}}

EXPECTED_RESPONSE_STATUS 200
EXPECTED_RESPONSE_BODY "first"
EXPECTED_RESPONSE_BODY "3.0.0"

###

# @name request-one
GET __BASE_URL__/status/200

EXPECTED_RESPONSE_STATUS 200

###

# @name request-two
# @dependsOn request-one
POST __BASE_URL__/post
Content-Type: application/json

{
  "username": "{{expected_user_name}}",
  "action": "create_user"
}

EXPECTED_RESPONSE_STATUS 200

###

# @name request-three
# @if request-two.response.status 200
# @if request-two.response.body.$.json.username testuser123
GET __BASE_URL__/json

EXPECTED_RESPONSE_STATUS 200
EXPECTED_RESPONSE_BODY "slideshow"

###

# @name not-found
GET __BASE_URL__/status/404

EXPECTED_RESPONSE_STATUS 404

###

# @name fallback
# @if-not not-found.response.status 200
GET __BASE_URL__/json

EXPECTED_RESPONSE_STATUS 200

###

# @name check_health
GET __BASE_URL__/health

EXPECTED_RESPONSE_STATUS 200

###

# @name create_user
POST __BASE_URL__/api/users
Content-Type: application/json
Authorization: Bearer dev-token-12345

{
  "username": "local-user",
  "email": "test@example.com"
}

EXPECTED_RESPONSE_STATUS 201

###

# @name get_user
# @dependsOn create_user
GET __BASE_URL__/api/users/{{create_user.response.body.$.id}}
Authorization: Bearer dev-token-12345

EXPECTED_RESPONSE_STATUS 200
EXPECTED_RESPONSE_BODY "local-user"

###

# @name delayed
# @timeout 200 ms
# @pre-delay 10
# @post-delay 10
GET __BASE_URL__/delay/40

EXPECTED_RESPONSE_STATUS 200
