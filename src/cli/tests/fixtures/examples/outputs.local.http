# Curated local mirror focused on log/report/export coverage and redaction behavior.

# @name sensitive_payload
POST __BASE_URL__/post?token=query-secret
Content-Type: application/json
Authorization: Bearer secret-token
X-Api-Key: api-secret

{
  "token": "secret-token",
  "password": "supersecret",
  "name": "john"
}

EXPECTED_RESPONSE_STATUS 200
EXPECTED_RESPONSE_BODY "john"
