# Curated local mirror of IntelliJ HTTP client script-block handling.

POST __BASE_URL__/post
Content-Type: application/json

{
  "test": "data",
  "value": 123
}

> {%
    client.test("Request executed successfully", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });
%}

###

GET __BASE_URL__/json

> {%
    client.test("Response is valid JSON", function() {
        client.assert(response.body.hasOwnProperty('slideshow'), "Missing slideshow property");
        client.log("Response processed");
    });
%}

###

GET __BASE_URL__/uuid

EXPECTED_RESPONSE_STATUS 200
EXPECTED_RESPONSE_BODY "uuid"
