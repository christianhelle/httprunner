# Curated local mirror for http-client.env.json loading.

@DefaultHost=local.test

GET {{HostAddress}}/get?environment={{Environment}}
Accept: application/json
Authorization: Bearer {{ApiKey}}
X-Environment: {{Environment}}
X-Host: {{DefaultHost}}

EXPECTED_RESPONSE_STATUS 200
EXPECTED_RESPONSE_BODY "local"
EXPECTED_RESPONSE_BODY "env-secret"

###

POST {{HostAddress}}/post
Content-Type: application/json
Authorization: Bearer {{ApiKey}}

{
  "environment": "{{Environment}}",
  "host": "{{HostAddress}}",
  "apiKey": "{{ApiKey}}"
}

EXPECTED_RESPONSE_STATUS 200
EXPECTED_RESPONSE_BODY "env-secret"
